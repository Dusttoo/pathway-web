# Pathway Web App — Environment Variables
# Copy to .env.development (local) or set in your deployment environment.
# Never commit real secrets to git.

# ==================== Environment ====================
ENVIRONMENT=development          # development | staging | production
LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR
DEBUG=false

# ==================== Discord OAuth ====================
# Create an app at https://discord.com/developers/applications
# OAuth2 → Redirects: add your DISCORD_REDIRECT_URI
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
DISCORD_REDIRECT_URI=http://localhost:8000/api/v1/auth/discord/callback

# Optional: webhook URL for staff/error notifications
# DISCORD_STAFF_WEBHOOK_URL=https://discord.com/api/webhooks/...

# ==================== Database ====================
# Supabase: Settings → Database → Connection string (Session mode, port 5432)
DATABASE_HOST=db.cmmwirlrvqmjqbydlqks.supabase.co
DATABASE_PORT=5432
DATABASE_NAME=postgres
DATABASE_USER=postgres
DATABASE_PASSWORD=your_supabase_db_password
DATABASE_SSL_MODE=require        # use 'disable' for local Docker postgres

# ==================== API ====================
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1                    # increase in production (e.g. 4)
API_RELOAD=true                  # set false in production
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=["http://localhost:3000"]

# ==================== Security ====================
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=your_jwt_secret_here
JWT_EXPIRATION_MINUTES=10080     # 7 days; reduce to 60 in production

# ==================== Stripe ====================
# Get from https://dashboard.stripe.com/apikeys
# Use sk_test_... for dev/staging; sk_live_... for production only
STRIPE_API_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# ==================== Storage ====================
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10
S3_ENABLED=false
# S3_BUCKET_NAME=your-bucket
# S3_REGION=us-east-1
# S3_ACCESS_KEY_ID=...
# S3_SECRET_ACCESS_KEY=...
# S3_PUBLIC_URL=https://cdn.yourdomain.com

# ==================== Monitoring ====================
# Sign up at https://sentry.io, create a Python project
# SENTRY_DSN_API=https://...@sentry.io/...
